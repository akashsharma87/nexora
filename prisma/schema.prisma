generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  properties            Property[]
  users                 User[]
  adPlatformConnections AdPlatformConnection[]
}

model Property {
  id                   String            @id @default(cuid())
  organizationId       String
  name                 String
  address              String?
  city                 String?
  // Drives Priya's default call/message language (lib/ai-calling.ts → calling-server/server.js):
  // "India" defaults to Hinglish, anything else defaults to English. Free text, not an enum —
  // matched case-insensitively against "india" rather than constrained to a fixed list.
  country              String            @default("India")
  // ISO 4217 currency code the property's own budget/revenue figures are denominated in (e.g. a
  // Kenya-based client's lead sheet holds KES amounts, not INR). Free text like `country`, not an
  // enum. Drives lib/format.ts's formatCurrency — INR keeps the existing ₹ Lakh/Crore convention;
  // any other code is formatted as a plain amount in that currency, with NO Lakh-style
  // multiplication (that convention is an India-only sheet habit, see formatCurrency).
  currency             String            @default("INR")
  // Business type this property runs, selecting the AI voice-agent persona + qualification flow
  // (lib/ai-calling.ts → calling-server/server.js buildInstructions). Free text (like `country`/
  // `currency`), NOT an enum, so a new vertical never needs a migration. "banquet" (default) is
  // the original banquet/event coordinator flow — unchanged for every existing client. "apartments"
  // is the Kika-style real-estate rental flow. Anything unrecognised falls back to "banquet".
  vertical             String            @default("banquet")
  phone                String?
  email                String?
  logoUrl              String?
  metaAdAccountId      String?
  metaAdAccountName    String?
  googleAdsCustomerId  String?
  googleAdsAccountName String?
  autoAiCallingEnabled Boolean           @default(false)
  autoWhatsappNurtureEnabled Boolean     @default(false)
  // Client's public website — source for the AI-caller Knowledge Base (see KnowledgeBase below).
  websiteUrl           String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  organization         Organization      @relation(fields: [organizationId], references: [id])
  users                UserProperty[]
  leads                Lead[]
  campaigns            Campaign[]
  listings             PlatformListing[]
  templates            MessageTemplate[]
  knowledgeBase        KnowledgeBase?
}

// One-time (re-runnable) scrape of Property.websiteUrl, distilled into a bounded list of ~15-20
// key facts that get injected into Priya's (AI caller) system prompt — see calling-server/server.js
// buildInstructions(). Deliberately NOT a live vector-search/RAG index: for a realtime voice call,
// latency matters more than corpus size, and a venue's key facts comfortably fit a capped list.
model KnowledgeBase {
  id            String          @id @default(cuid())
  propertyId    String          @unique
  sourceUrl     String?         // URL last scraped (mirrors Property.websiteUrl at scrape time)
  status        KnowledgeStatus @default(EMPTY)
  pagesScraped  Int             @default(0)
  // THE payload Priya uses — a JSON array of KeyFact: { category, fact, source }, where
  // source is "scrape" | "manual". `source` lets a re-crawl/regenerate replace only
  // scrape-derived facts while PRESERVING hand-added ones, so staff edits are never wiped.
  // This is the only field the calling server reads (via /api/internal/knowledge-facts).
  keyFacts      Json?
  factsCount    Int             @default(0)
  lastScrapedAt DateTime?
  error         String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  pages         KnowledgePage[]
}

// Cleaned per-page text from the crawl. Kept around so facts can be regenerated without
// re-scraping the site (see recompileFacts in lib/knowledge/runner.ts).
model KnowledgePage {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  url             String
  title           String?
  content         String        @db.Text
  contentHash     String        // sha256 of content; skips near-dupe boilerplate pages on re-crawl
  wordCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@unique([knowledgeBaseId, url])
  @@index([knowledgeBaseId])
}

enum KnowledgeStatus {
  EMPTY       // no scrape yet
  PENDING     // queued, runner not started
  PROCESSING  // crawl/extract in progress
  READY       // key facts available
  FAILED      // see `error`
}

model User {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  email          String         @unique
  password       String
  role           UserRole       @default(EXECUTIVE)
  phone          String?
  avatarUrl      String?
  isActive       Boolean        @default(true)
  // Persistent handle for an auto-provisioned Internet Moguls staff seat
  // (mogul-1/2/3 per project). Independent of `name` so the person can
  // rename themselves after first login without losing which seat they are.
  staffTag       StaffTag?
  // Encrypted copy of the auto-generated password (see lib/credential-crypto.ts),
  // set only for auto-provisioned staffTag accounts — lets an OWNER/MANAGER
  // re-reveal the login credentials to hand off, since bcrypt (`password` above)
  // cannot be reversed. Null for normal user-created accounts.
  tempCredential String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id])
  properties     UserProperty[]
  assignedLeads  Lead[]         @relation("AssignedLeads")
  activities     LeadActivity[]
  tasks          Task[]         @relation("TaskAssignee")
  sessions       Session[]
  accounts       Account[]
}

enum UserRole {
  OWNER
  MANAGER
  EXECUTIVE
}

enum StaffTag {
  MOGUL_1
  MOGUL_2
  MOGUL_3
}

model UserProperty {
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id                String               @id @default(cuid())
  propertyId        String
  name              String
  email             String?
  phone             String
  eventType         EventType
  eventDate         DateTime?
  guestCount        Int?
  budgetMin         Decimal?
  budgetMax         Decimal?
  source            LeadSource
  // The sheet tab this lead was originally imported from (e.g. "Wedding", "Kitty Party").
  // Set once at creation and never overwritten — a later phone-match sync from a different
  // tab must not reassign it, since AI-calling/WhatsApp automation branches on this value.
  sourceTab         String?
  stage             LeadStage            @default(NEW)
  leadScore         Int                  @default(50)
  notes             String?              @db.Text
  assignedToId      String?
  lostReason        String?
  campaignId        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  property          Property             @relation(fields: [propertyId], references: [id])
  assignedTo        User?                @relation("AssignedLeads", fields: [assignedToId], references: [id])
  campaign          Campaign?            @relation(fields: [campaignId], references: [id])
  activities        LeadActivity[]
  proposals         Proposal[]
  tasks             Task[]
  scheduledMessages ScheduledMessage[]
  externalSources   LeadExternalSource[]
  aiCalls           AiCall[]
}

enum LeadStage {
  NEW
  CONTACTED
  FOLLOW_UP
  SITE_VISIT
  PROPOSAL_SENT
  NEGOTIATION
  BOOKED
  LOST
}

enum EventType {
  SOCIAL_EVENTS
  CORPORATE_EVENTS
  BIRTHDAY_SOCIAL
  PROMOTIONAL_EVENTS
  ENTERTAINMENT_EVENTS
  SEASONAL_THEMATIC
}

enum LeadSource {
  WEDMEGOOD
  WEDDINGZ
  VENUELOOK
  WEDDINGBAZAAR
  GOOGLE
  META
  JUSTDIAL
  WALK_IN
  REFERRAL
  PHONE
  DIRECT
  OTHER
}

model LeadActivity {
  id        String       @id @default(cuid())
  leadId    String
  userId    String
  type      ActivityType
  content   String       @db.Text
  metadata  Json?
  createdAt DateTime     @default(now())
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])
}

enum ActivityType {
  STAGE_CHANGE
  NOTE
  CALL_LOGGED
  WHATSAPP_SENT
  EMAIL_SENT
  PROPOSAL_SENT
  SITE_VISIT_SCHEDULED
  TASK_CREATED
  TASK_COMPLETED
  LEAD_CREATED
}

model Campaign {
  id             String         @id @default(cuid())
  propertyId     String
  externalId     String?
  name           String
  type           CampaignType
  platforms      CampaignPlatform[]
  budgetAmount   Decimal
  spentAmount    Decimal        @default(0)
  leadsGenerated Int            @default(0)
  bookingsCount  Int            @default(0)
  status         CampaignStatus @default(ACTIVE)
  startDate      DateTime
  endDate        DateTime?
  targetAudience Json?
  keywords       String[]
  creatives      Json?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  property       Property       @relation(fields: [propertyId], references: [id])
  leads          Lead[]

  @@unique([propertyId, externalId])
}

enum CampaignType {
  SOCIAL_EVENTS
  CORPORATE_EVENTS
  BIRTHDAY_SOCIAL
  PROMOTIONAL_EVENTS
  ENTERTAINMENT_EVENTS
  SEASONAL_THEMATIC
}

enum CampaignPlatform {
  META
  GOOGLE
  INSTAGRAM
  LINKEDIN
  EMAIL
  WHATSAPP
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model PlatformListing {
  id               String        @id @default(cuid())
  propertyId       String
  platform         ListingPlatform
  status           ListingStatus @default(ACTIVE)
  tier             String?
  profileUrl       String?
  leadsGenerated   Int           @default(0)
  revenueGenerated Decimal       @default(0)
  contentScore     Int           @default(0)
  contentChecklist Json?
  lastUpdatedAt    DateTime?
  lastSyncAt       DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  property         Property      @relation(fields: [propertyId], references: [id])
}

enum ListingPlatform {
  WEDMEGOOD
  WEDDINGZ
  VENUELOOK
  WEDDINGBAZAAR
  GOOGLE_BUSINESS
  JUSTDIAL
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
  SUSPENDED
}

model MessageTemplate {
  id         String       @id @default(cuid())
  propertyId String?
  name       String
  type       TemplateType
  content    String       @db.Text
  variables  String[]
  isActive   Boolean      @default(true)
  sentCount  Int          @default(0)
  openRate   Decimal      @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  property   Property?    @relation(fields: [propertyId], references: [id])
}

enum TemplateType {
  INITIAL_RESPONSE
  NURTURE_DAY1
  NURTURE_DAY3
  NURTURE_DAY5
  NURTURE_DAY7
  PROPOSAL_FOLLOWUP
  POST_EVENT_DAY3
  POST_EVENT_DAY30
  POST_EVENT_DAY90
  BROADCAST
  CUSTOM
}

model AutomationFlow {
  id         String   @id @default(cuid())
  propertyId String?
  name       String
  trigger    String
  isActive   Boolean  @default(true)
  steps      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BroadcastCampaign {
  id          String          @id @default(cuid())
  propertyId  String
  name        String
  templateId  String?
  message     String          @db.Text
  scheduledAt DateTime?
  sentAt      DateTime?
  status      BroadcastStatus @default(DRAFT)
  recipients  Int             @default(0)
  delivered   Int             @default(0)
  opened      Int             @default(0)
  responded   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Proposal {
  id         String         @id @default(cuid())
  leadId     String
  title      String
  content    String         @db.Text
  amount     Decimal?
  eventDate  DateTime?
  guestCount Int?
  validUntil DateTime?
  status     ProposalStatus @default(DRAFT)
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  declinedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  lead       Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

model Task {
  id           String     @id @default(cuid())
  leadId       String?
  assignedToId String?
  title        String
  description  String?
  dueDate      DateTime?
  priority     Priority   @default(MEDIUM)
  completed    Boolean    @default(false)
  completedAt  DateTime?
  source       TaskSource @default(MANUAL)
  // Null until the assignee has viewed it on their dashboard — drives the
  // "Priya assigned you N new tasks" notification for AI_CALL-sourced tasks.
  seenAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
}

enum TaskSource {
  MANUAL
  AI_CALL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── AUTOMATION EXECUTION ─────────────────────────────────────────────────────

model ScheduledMessage {
  id           String        @id @default(cuid())
  leadId       String
  templateType TemplateType
  phone        String
  payload      Json
  scheduledAt  DateTime
  sentAt       DateTime?
  status       MessageStatus @default(PENDING)
  error        String?       @db.Text
  retryCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
  SKIPPED
}

// ─── WEBHOOK LOGGING ──────────────────────────────────────────────────────────

model WebhookEvent {
  id        String   @id @default(cuid())
  source    String
  eventType String
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())
}

// ─── GOOGLE SHEETS INTEGRATIONS ───────────────────────────────────────────────

model IntegrationConnection {
  id             String              @id @default(cuid())
  organizationId String
  propertyId     String
  provider       IntegrationProvider
  name           String
  source         LeadSource
  sheetId        String?
  tabName        String?             @default("Sheet1")
  headerRow      Int                 @default(1)
  columnMap      Json
  status         IntegrationStatus   @default(ACTIVE)
  lastSyncedAt   DateTime?
  lastSyncCount  Int                 @default(0)
  lastSyncStatus String?
  lastSyncError  String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  externalSources LeadExternalSource[]
}

model LeadExternalSource {
  id           String               @id @default(cuid())
  leadId       String
  connectionId String?
  provider     IntegrationProvider
  externalId   String
  sourceTab    String?
  rowHash      String?
  rawPayload   Json?
  createdAt    DateTime             @default(now())
  lead         Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
}

enum IntegrationProvider {
  GOOGLE_SHEETS
  CSV
  WEBSITE_FORM
  META_LEADS
  GOOGLE_ADS
  MANUAL
}

enum IntegrationStatus {
  ACTIVE
  PAUSED
  ERROR
}

// ─── AD PLATFORM MASTER CONNECTIONS (agency-level OAuth) ──────────────────────
// One row per organization per platform: the agency authenticates its master
// Business Manager / MCC once, and every property picks its ad account from
// the list that master token can see (fields above on Property).

model AdPlatformConnection {
  id                String            @id @default(cuid())
  organizationId    String
  platform          AdPlatform
  accessToken       String            @db.Text
  refreshToken      String?           @db.Text
  tokenExpiresAt    DateTime?
  externalId        String?
  connectedByUserId String?
  status            IntegrationStatus @default(ACTIVE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, platform])
}

enum AdPlatform {
  META
  GOOGLE_ADS
}

// ─── AI VOICE CALLING ─────────────────────────────────────────────────────────

model AiCall {
  id             String        @id @default(cuid())
  leadId         String
  propertyId     String
  callSid        String?       @unique
  status         AiCallStatus  @default(PENDING)
  outcome        CallOutcome?
  qualifiedScore Int?
  transcript     Json?
  recordingUrl   String?
  duration       Int?
  notes          String?       @db.Text
  scheduledAt    DateTime?
  callStartedAt  DateTime?
  callEndedAt    DateTime?
  attempts       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([leadId])
  @@index([status, scheduledAt])
}

enum AiCallStatus {
  PENDING
  DIALING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELLED
}

enum CallOutcome {
  QUALIFIED
  NOT_QUALIFIED
  CALLBACK
  WRONG_NUMBER
  VOICEMAIL
  UNKNOWN
}
